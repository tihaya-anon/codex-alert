{
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CODEX_HOOKS_DIR:-$PWD/.codex/hooks}/run-powershell-hook.sh\" -NoProfile -ExecutionPolicy Bypass -File \"${CODEX_HOOKS_DIR:-$PWD/.codex/hooks}/main.ps1\" -Action approval",
            "timeout": 15,
            "statusMessage": "Notifying approval request"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CODEX_HOOKS_DIR:-$PWD/.codex/hooks}/clear-approval-toast-if-active.sh\"",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CODEX_HOOKS_DIR:-$PWD/.codex/hooks}/session-end-toast.sh\"",
            "timeout": 15,
            "statusMessage": "Notifying conversation end"
          }
        ]
      }
    ]
  }
}
